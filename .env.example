# ── Supabase ─────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Claude API ───────────────────────────────────────────
# From console.anthropic.com → API keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Granola (optional at first) ──────────────────────────
# GRANOLA_MODE=paste  → paste notes by hand in the dashboard (works day one)
# GRANOLA_MODE=mcp    → fetch notes live from Granola's hosted MCP server
GRANOLA_MODE=paste
# OAuth bearer token for https://mcp.granola.ai/mcp (mcp mode only)
GRANOLA_MCP_AUTH_TOKEN=YOUR_GRANOLA_MCP_OAUTH_TOKEN

# ── Share links ──────────────────────────────────────────
# Any long random string. Used to hash share tokens.
SHARE_LINK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# How many days a share link stays live
SHARE_LINK_EXPIRY_DAYS=14

# Base URL of the deployed app, for building share links
NEXT_PUBLIC_APP_URL=http://localhost:3000
